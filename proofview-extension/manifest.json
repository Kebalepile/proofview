{
  "manifest_version": 3,
  "name": "ProofView",
  "version": "1.0.0",
  "description": "Minimal Gmail email tracking MVP",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://proofview.onrender.com/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_title": "ProofView",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "css": [
        "content/gmail_content.css"
      ],
      "js": [
        "shared/config.js",
        "content/gmail_content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
